# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Google 3D Tiles ──────────────────────────────────────────────────────────
# How to get: https://console.cloud.google.com → APIs & Services → Credentials
# Enable the "Map Tiles API" before generating a key.
GOOGLE_3D_TILES_API_KEY=

# ─── Aircraft Tracking ────────────────────────────────────────────────────────
# Register free at https://opensky-network.org
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
# Optional: ADS-B Exchange key from https://rapidapi.com/adsbx/api/adsbexchange-com1
ADSB_EXCHANGE_API_KEY=

# ─── Satellite Tracking ───────────────────────────────────────────────────────
# CelesTrak is free and open — no API key required
CELESTRAK_BASE_URL=https://celestrak.org

# ─── Maritime Tracking ────────────────────────────────────────────────────────
# Register free at https://aisstream.io
AIS_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for development)
DATABASE_URL=sqlite://./data/omnirecon.db
# PostgreSQL example (use in production):
# DATABASE_URL=postgresql://user:password@host:5432/omnirecon

# ─── WebSocket ────────────────────────────────────────────────────────────────
WS_PORT=3001

# ─── Replay ───────────────────────────────────────────────────────────────────
# Number of days to retain OSINT event history for replay
REPLAY_RETENTION_DAYS=30

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_CCTV=true
ENABLE_JAMMING=true
ENABLE_BLACKOUTS=true
ENABLE_REPLAY=true
